<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="clr-namespace:nv_color_profiles.localization"
        x:Class="nv_color_profiles.views.licenses_window"
        Title="{i18n:tr licenses.title}"
        Width="780" Height="640"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="close_button" Content="{i18n:tr close}" MinWidth="110" />
    </StackPanel>

    <ComboBox x:Name="doc_combo" DockPanel.Dock="Top" HorizontalAlignment="Stretch" Margin="0,0,0,10" />

    <Border BorderThickness="1" BorderBrush="#33FFFFFF" CornerRadius="4">
      <TextBox x:Name="doc_text"
               IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
               Background="Transparent" BorderThickness="0" Padding="10"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Auto" />
    </Border>

  </DockPanel>
</Window>
