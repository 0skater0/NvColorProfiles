<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="clr-namespace:nv_color_profiles.localization"
        x:Class="nv_color_profiles.views.text_prompt"
        Width="380" SizeToContent="Height"
        CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="14">
    <TextBox x:Name="input" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="ok_button" Content="{i18n:tr ok}" MinWidth="84" Classes="accent" IsDefault="True" />
      <Button x:Name="cancel_button" Content="{i18n:tr cancel}" MinWidth="92" IsCancel="True" />
    </StackPanel>
  </StackPanel>
</Window>
